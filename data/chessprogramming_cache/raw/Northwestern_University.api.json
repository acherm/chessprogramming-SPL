      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * Northwestern University</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:TechInstitute-PostLakefill.jpg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/TechInstitute-PostLakefill.jpg/330px-TechInstitute-PostLakefill.jpg\" width=\"300\" height=\"293\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/4/47/TechInstitute-PostLakefill.jpg/500px-TechInstitute-PostLakefill.jpg 1.5x, https://upload.wikimedia.org/wikipedia/commons/4/47/TechInstitute-PostLakefill.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:TechInstitute-PostLakefill.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>Technological Institute, Post Lakefill, 1977 <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></div></div></div>\n<p><b>Northwestern University</b> in <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Evanston,_Illinois\">Evanston</a> and downtown <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Chicago\">Chicago</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Illinois\">Illinois</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/United_States\">United States</a>. The Vogelback Computer Center headed by <a href=\"/Ben_Mittman\" title=\"Ben Mittman\">Ben Mittman</a> was the first building constructed on the <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Northwestern_University_Lakefill\">Lakefill</a> in Evanston <sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\">&#91;2&#93;</a></sup>.  \n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#People\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">People</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Chess_Programs_and_Authors\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Chess Programs and Authors</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Tournaments\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Tournaments</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#External_Links\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-5\"><a href=\"#References\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"People\">People</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Northwestern_University&amp;action=edit&amp;section=1\" title=\"Edit section: People\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Larry_Atkin\" title=\"Larry Atkin\">Larry Atkin</a></li>\n<li> <a href=\"/William_Blanchard\" title=\"William Blanchard\">William Blanchard</a></li>\n<li> <a href=\"/Joe_Condon\" title=\"Joe Condon\">Joe Condon</a></li>\n<li> <a href=\"/Mathematician#CEnrothCugell\" title=\"Mathematician\">Christina Enroth-Cugell</a></li>\n<li> <a href=\"/Keith_Gorlen\" title=\"Keith Gorlen\">Keith Gorlen</a></li>\n<li> <a href=\"/Peter_W._Frey\" title=\"Peter W. Frey\">Peter W. Frey</a></li>\n<li> <a href=\"/Donald_H._Mitchell\" title=\"Donald H. Mitchell\">Donald H. Mitchell</a></li>\n<li> <a href=\"/Ben_Mittman\" title=\"Ben Mittman\">Ben Mittman</a></li>\n<li> <a href=\"/index.php?title=Judith_Spencer_Olson&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Judith Spencer Olson (page does not exist)\">Judith Spencer Olson</a></li>\n<li> <a href=\"/David_Slate\" title=\"David Slate\">David Slate</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Chess_Programs_and_Authors\">Chess Programs and Authors</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Northwestern_University&amp;action=edit&amp;section=2\" title=\"Edit section: Chess Programs and Authors\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Chess_(Program)\" title=\"Chess (Program)\">Chess</a>\n<ul><li> <a href=\"/Larry_Atkin\" title=\"Larry Atkin\">Larry Atkin</a></li>\n<li> <a href=\"/David_Cahlander\" title=\"David Cahlander\">David Cahlander</a> from <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Control_Data_Corporation\">Control Data Corporation</a></li>\n<li> <a href=\"/Keith_Gorlen\" title=\"Keith Gorlen\">Keith Gorlen</a></li>\n<li> <a href=\"/David_Slate\" title=\"David Slate\">David Slate</a></li></ul></li>\n<li> <a href=\"/Chess_0.5\" title=\"Chess 0.5\">Chess 0.5</a>\n<ul><li> <a href=\"/Larry_Atkin\" title=\"Larry Atkin\">Larry Atkin</a></li>\n<li> <a href=\"/Peter_W._Frey\" title=\"Peter W. Frey\">Peter W. Frey</a></li></ul></li>\n<li> <a href=\"/Nuchess\" title=\"Nuchess\">Nuchess</a>\n<ul><li> <a href=\"/William_Blanchard\" title=\"William Blanchard\">William Blanchard</a></li>\n<li> <a href=\"/David_Slate\" title=\"David Slate\">David Slate</a></li></ul></li></ul>\n<h1><span class=\"mw-headline\" id=\"Tournaments\">Tournaments</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Northwestern_University&amp;action=edit&amp;section=3\" title=\"Edit section: Tournaments\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/ACM_1971\" title=\"ACM 1971\">ACM 1971</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"External_Links\">External Links</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Northwestern_University&amp;action=edit&amp;section=4\" title=\"Edit section: External Links\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.northwestern.edu/\">Official website</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/History_of_Northwestern_University\">History of Northwestern University from Wikipedia</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Northwestern_University\">Northwestern University from Wikipedia</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Northwestern_University_Lakefill\">Northwestern University Lakefill from Wikipedia</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Northwestern_Technological_Institute\">Northwestern Technological Institute</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://digital.library.northwestern.edu/architecture/building.php?bid=24\">The Lakefill - University Archives</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.northwestern.edu/magazine/northwestern/spring2001/brick_feature.htm\">Brick by Brick - Northwestern Magazine - Spring 2001</a></li>\n<li> <a href=\"/Category:Chicago\" title=\"Category:Chicago\">Chicago</a> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Chicago_at_Carnegie_Hall\">at Carnegie Hall 1971</a> - <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/25_or_6_to_4\">25 or 6 to 4</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/YouTube\">YouTube</a> Video</li></ul>\n<dl><dd> <div class='embedvideo ev_inline ev_top autoResize' style=' width: 646px;'><div class='embedvideowrap' style='