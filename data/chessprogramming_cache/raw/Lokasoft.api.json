      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * Lokasoft</b>\n</p><p><b>Lokasoft</b>,<br />\na Dutch chess software developing and trading company directed by <a href=\"/Lex_Loep\" title=\"Lex Loep\">Lex Loep</a>, established since 1992 <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup>. \nIn 2002 Lokasoft took over the activities of <a href=\"/Ed_Schroder\" title=\"Ed Schroder\">Schröder BV</a> <sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\">&#91;2&#93;</a></sup>.\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Products\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Products</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Former_Products\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Former Products</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#External_Links\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#References\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"Products\">Products</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Lokasoft&amp;action=edit&amp;section=1\" title=\"Edit section: Products\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<p><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\">&#91;3&#93;</a></sup>\n</p>\n<ul><li> <a href=\"/ChessPartner\" title=\"ChessPartner\">ChessPartner</a> by <a href=\"/Lex_Loep\" title=\"Lex Loep\">Lex Loep</a> <sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\">&#91;4&#93;</a></sup></li>\n<li> <a href=\"/SmarThink\" title=\"SmarThink\">SmarThink</a> by <a href=\"/Sergei_Markoff\" title=\"Sergei Markoff\">Sergei Markoff</a> <sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\">&#91;5&#93;</a></sup></li>\n<li> <a href=\"/Ktulu\" title=\"Ktulu\">Ktulu</a> by <a href=\"/Rahman_Paidar\" title=\"Rahman Paidar\">Rahman Paidar</a> <sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\">&#91;6&#93;</a></sup></li>\n<li> <a href=\"/Chess_Tiger\" title=\"Chess Tiger\">Chess Tiger</a> by <a href=\"/Christophe_Th%C3%A9ron\" title=\"Christophe Théron\">Christophe Théron</a> <sup id=\"cite_ref-7\" class=\"reference\"><a href=\"#cite_note-7\">&#91;7&#93;</a></sup></li>\n<li> <a href=\"/Rebel\" title=\"Rebel\">Rebel 12</a> by <a href=\"/Ed_Schroder\" title=\"Ed Schroder\">Ed Schröder</a> <sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\">&#91;8&#93;</a></sup></li></ul>\n<h1><span class=\"mw-headline\" id=\"Former_Products\">Former Products</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Lokasoft&amp;action=edit&amp;section=2\" title=\"Edit section: Former Products\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Deep_Sjeng\" title=\"Deep Sjeng\">Deep Sjeng 1.0/1.5/1.6</a> by <a href=\"/Gian-Carlo_Pascutto\" title=\"Gian-Carlo Pascutto\">Gian-Carlo Pascutto</a></li>\n<li> <a href=\"/Gandalf\" title=\"Gandalf\">Gandalf 6</a> by <a href=\"/Steen_Suurballe\" title=\"Steen Suurballe\">Steen Suurballe</a> and <a href=\"/Dan_Wulff\" title=\"Dan Wulff\">Dan Wulff</a> <sup id=\"cite_ref-9\" class=\"reference\"><a href=\"#cite_note-9\">&#91;9&#93;</a></sup></li>\n<li> <a href=\"/Ruffian\" title=\"Ruffian\">Ruffian 2</a> by <a href=\"/Perola_Valfridsson\" title=\"Perola Valfridsson\">Perola Valfridsson</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"External_Links\">External Links</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Lokasoft&amp;action=edit&amp;section=3\" title=\"Edit section: External Links\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://shop.lokasoft.nl/en/\">Lokasoft Home</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://nl.wikipedia.org/wiki/Lokasoft\">Lokasoft - Wikipedia.nl</a> (Dutch)</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/home.aspx\">Home - Lokasoft - Home of ChessPartner</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/SiteMap.aspx\">Site Map - Lokasoft - Home of ChessPartner</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/products.aspx\">Products - Lokasoft - Home of ChessPartner</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Lokasoft&amp;action=edit&amp;section=4\" title=\"Edit section: References\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://nl.wikipedia.org/wiki/Lokasoft\">Lokasoft - Wikipedia.nl</a> (Dutch)</span>\n</li>\n<li id=\"cite_note-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-2\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"http://www.rebel.nl/lokasoft.htm\">Company Information</a>, by <a href=\"/Ed_Schroder\" title=\"Ed Schroder\">Ed Schröder</a> and <a href=\"/Lex_Loep\" title=\"Lex Loep\">Lex Loep</a>, September 1, 2002</span>\n</li>\n<li id=\"cite_note-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-3\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/home.aspx\">Home - Lokasoft - Home of ChessPartner</a></span>\n</li>\n<li id=\"cite_note-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-4\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/chesspartner.aspx\">ChessPartner 6</a></span>\n</li>\n<li id=\"cite_note-5\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-5\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/smarthink_120.aspx\">SmarThink 1.20</a> (as of July 2020, no longer available)</span>\n</li>\n<li id=\"cite_note-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-6\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/ktulu.aspx\">Ktulu</a> (as of July 2020, no longer available)</span>\n</li>\n<li id=\"cite_note-7\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-7\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/chess_tiger_2007.aspx\">Chess Tiger 2007</a> (as of July 2020, no longer available)</span>\n</li>\n<li id=\"cite_note-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-8\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/rebel12.aspx\">Rebel 12</a> (as of July 2020, no longer available)</span>\n</li>\n<li id=\"cite_note-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-9\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://www.lokasoft.nl/gandalf6.aspx\">Gandalf 6</a></span>\n</li>\n</ol></div>\n<p><b><a href=\"/Organizations\" title=\"Organizations\">Up one Level</a></b>\n</p>\n<!-- \nNewPP limit report\nC