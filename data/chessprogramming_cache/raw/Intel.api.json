      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * Intel</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:2200missioncollegeblvd.jpg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/2200missioncollegeblvd.jpg/330px-2200missioncollegeblvd.jpg\" width=\"300\" height=\"202\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/2200missioncollegeblvd.jpg/500px-2200missioncollegeblvd.jpg 1.5x, https://upload.wikimedia.org/wikipedia/commons/thumb/c/ce/2200missioncollegeblvd.jpg/960px-2200missioncollegeblvd.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:2200missioncollegeblvd.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>Intel headquarters, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Santa_Clara,_California\">Santa Clara, CA</a> <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></div></div></div> \n<p><b>Intel Corporation</b>,<br />\nan American global technology company and the world's largest <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Semiconductor\">semiconductor</a> manufacturer <sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\">&#91;2&#93;</a></sup> , most famous for their <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Microprocessor\">microprocessors</a>, starting in 1971 with the first general-purpose, commercial microprocessor, the <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_4004\">4004</a> <sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\">&#91;3&#93;</a></sup>. \n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Sponsoring\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Sponsoring</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Architectures\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Architectures</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#SIMD_Extensions\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">SIMD Extensions</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#General_Purpose_Extensions\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">General Purpose Extensions</span></a></li>\n<li class=\"toclevel-1 tocsection-5\"><a href=\"#Development\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">Development</span></a></li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#Manuals\"><span class=\"tocnumber\">6</span> <span class=\"toctext\">Manuals</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-7\"><a href=\"#Instructions\"><span class=\"tocnumber\">6.1</span> <span class=\"toctext\">Instructions</span></a></li>\n<li class=\"toclevel-2 tocsection-8\"><a href=\"#Optimization_Guides\"><span class=\"tocnumber\">6.2</span> <span class=\"toctext\">Optimization Guides</span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-9\"><a href=\"#See_also\"><span class=\"tocnumber\">7</span> <span class=\"toctext\">See also</span></a></li>\n<li class=\"toclevel-1 tocsection-10\"><a href=\"#Forum_Posts\"><span class=\"tocnumber\">8</span> <span class=\"toctext\">Forum Posts</span></a></li>\n<li class=\"toclevel-1 tocsection-11\"><a href=\"#External_Links\"><span class=\"tocnumber\">9</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-12\"><a href=\"#References\"><span class=\"tocnumber\">10</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"Sponsoring\">Sponsoring</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=1\" title=\"Edit section: Sponsoring\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/WCCC_2004\" title=\"WCCC 2004\">WCCC 2004</a>&#160;» <a rel=\"nofollow\" class=\"external text\" href=\"http://www.intel.com/cd/corporate/europe/emea/heb/287256.htm\">Intel Israel</a> <sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\">&#91;4&#93;</a></sup></li></ul>\n<h1><span class=\"mw-headline\" id=\"Architectures\">Architectures</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=2\" title=\"Edit section: Architectures\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<p><sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\">&#91;5&#93;</a></sup> \n</p>\n<table class=\"wikitable\">\n\n<tr>\n<th> Year\n</th>\n<th> Bits\n</th>\n<th> Family\n</th>\n<th> Architecture\n</th></tr>\n<tr>\n<th> 1971\n</th>\n<td style=\"text-align:right;\"> 4\n</td>\n<td style=\"text-align:center;\">\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_4004\">Intel 4004</a>\n</td></tr>\n<tr>\n<th> 1974\n</th>\n<td rowspan=\"2\" style=\"text-align:right;\"> 8\n</td>\n<td rowspan=\"2\" style=\"text-align:center;\"> <a href=\"/8080\" title=\"8080\">8080</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_8080\">Intel 8080</a>\n</td></tr>\n<tr>\n<th> 1977\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_8085\">Intel 8085</a>\n</td></tr>\n<tr>\n<th> 1978\n</th>\n<td rowspan=\"3\" style=\"text-align:right;\"> 16\n</td>\n<td rowspan=\"3\" style=\"text-align:center;\"> <a href=\"/8086\" title=\"8086\">8086</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_8086\">Intel 8086</a>\n</td></tr>\n<tr>\n<th> 1982\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_80186\">Intel 80186</a>\n</td></tr>\n<tr>\n<th> 1982\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_80286\">Intel 80286</a>\n</td></tr>\n<tr>\n<th> 1985\n</th>\n<td rowspan=\"2\" style=\"text-align:right;\"> 32\n</td>\n<td rowspan=\"2\" style=\"text-align:center;\"> <a href=\"/X86\" title=\"X86\">x86</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_80386\">Intel 80386</a>\n</td></tr>\n<tr>\n<th> 1989\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_80486\">Intel 80486</a>\n</td></tr>\n<tr>\n<th> 1989\n</th>\n<td style=\"text-align:right;\"> 64\n</td>\n<td style=\"text-align:center;\">   <a href=\"/I860\" title=\"I860\">i860</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_i860\">i860 XR</a>\n</td></tr>\n<tr>\n<th> 1993\n</th>\n<td rowspan=\"4\" style=\"text-align:right;\"> 32\n</td>\n<td rowspan=\"4\" style=\"text-align:center;\">  <a href=\"/X86\" title=\"X86\">x86</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/P5_%28microarchitecture%29\">P5  </a>\n</td></tr>\n<tr>\n<th> 1995\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/P6_%28microarchitecture%29\">P6 </a>\n</td></tr>\n<tr>\n<th> 2003\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Pentium_M\">Pentium M</a>\n</td></tr>\n<tr>\n<th> 2000\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/NetBurst_%28microarchitecture%29\">NetBurst </a>\n</td></tr>\n<tr>\n<th> 2001\n</th>\n<td style=\"text-align:right;\"> 64\n</td>\n<td style=\"text-align:center;\"> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Itanium#Architecture\">IA-64</a>\n</td>\n<td>  <a href=\"/Itanium\" title=\"Itanium\">Itanium</a>\n</td></tr>\n<tr>\n<th> 2005\n</th>\n<td style=\"text-align:right;\"> 32/64\n</td>\n<td style=\"text-align:center;\"> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_64#Intel_64\">EM64T</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/NetBurst_%28microarchitecture%29\">NetBurst </a>\n</td></tr>\n<tr>\n<th> 2006\n</th>\n<td rowspan=\"6\" style=\"text-align:right;\"> 32/64\n</td>\n<td rowspan=\"6\" style=\"text-align:center;\"> <a href=\"/X86-64\" title=\"X86-64\">x86-64</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Core_%28microarchitecture%29\">Core </a>\n</td></tr>\n<tr>\n<th> 2008\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Nehalem_%28microarchitecture%29\">Nehalem  </a>\n</td></tr>\n<tr>\n<th> 2008\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_Atom\">Intel Atom</a>\n</td></tr>\n<tr>\n<th> 2011\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Sandy_Bridge\">Sandy Bridge</a>\n</td></tr>\n<tr>\n<th> 2012\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Ivy_Bridge_%28microarchitecture%29\">Ivy Bridge</a>\n</td></tr>\n<tr>\n<th> 2013\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Haswell_%28microarchitecture%29\">Haswell</a>\n</td></tr>\n<tr>\n<th> 2013\n</th>\n<td style=\"text-align:right;\">  32\n</td>\n<td style=\"text-align:center;\">   <a href=\"/X86\" title=\"X86\">x86</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_Quark\">Intel Quark</a>\n</td></tr>\n<tr>\n<th> 2014\n</th>\n<td rowspan=\"7\" style=\"text-align:right;\">  32/64\n</td>\n<td rowspan=\"7\" style=\"text-align:center;\">   <a href=\"/X86-64\" title=\"X86-64\">x86-64</a>\n</td>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Broadwell_%28microarchitecture%29\">Broadwell</a>\n</td></tr>\n<tr>\n<th> 2015\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Skylake_%28microarchitecture%29\">Skylake</a>\n</td></tr>\n<tr>\n<th> 2016\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Kaby_Lake\">Kaby Lake</a>\n</td></tr>\n<tr>\n<th> 2019\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Cascade_Lake_(microarchitecture)\">Cascade Lake</a>\n</td></tr>\n<tr>\n<th rowspan=\"2\"> 2020\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Cooper_Lake_(microarchitecture)\">Cooper Lake</a>\n</td></tr>\n<tr>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Ice_Lake_(microprocessor)\">Ice Lake</a>\n</td></tr>\n<tr>\n<th> 2021\n</th>\n<td>  <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Sapphire_Rapids\">Sapphire Rapids</a>\n</td></tr></table>\n<h1><span class=\"mw-headline\" id=\"SIMD_Extensions\">SIMD Extensions</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=3\" title=\"Edit section: SIMD Extensions\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/MMX\" title=\"MMX\">MMX</a></li>\n<li> <a href=\"/SSE\" title=\"SSE\">SSE</a></li>\n<li> <a href=\"/SSE2\" title=\"SSE2\">SSE2</a></li>\n<li> <a href=\"/SSE3\" title=\"SSE3\">SSE3</a></li>\n<li> <a href=\"/SSSE3\" title=\"SSSE3\">SSSE3</a></li>\n<li> <a href=\"/SSE4\" title=\"SSE4\">SSE4</a></li>\n<li> <a href=\"/AVX\" title=\"AVX\">AVX</a></li>\n<li> <a href=\"/AVX2\" title=\"AVX2\">AVX2</a></li>\n<li> <a href=\"/AVX-512\" title=\"AVX-512\">AVX-512</a></li>\n<li> <a href=\"/index.php?title=AMX&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"AMX (page does not exist)\">AMX</a> <sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\">&#91;6&#93;</a></sup></li></ul>\n<h1><span class=\"mw-headline\" id=\"General_Purpose_Extensions\">General Purpose Extensions</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=4\" title=\"Edit section: General Purpose Extensions\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/BMI1\" title=\"BMI1\">BMI1</a></li>\n<li> <a href=\"/BMI2\" title=\"BMI2\">BMI2</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Development\">Development</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=5\" title=\"Edit section: Development\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_C%2B%2B_Compiler\">Intel C++ Compiler from Wikipedia</a>&#160;» <a href=\"/C\" title=\"C\">C</a>, <a href=\"/Cpp\" title=\"Cpp\">C++</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Intel_Fortran_Compiler\">Intel Fortran Compiler from Wikipedia</a>&#160;» <a href=\"/Fortran\" title=\"Fortran\">Fortran</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://software.intel.com/en-us\">Intel® Software</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://software.intel.com/en-us/compilers\">Compilers from Intel | Intel® Software</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://software.intel.com/en-us/articles/intel-c-compiler-professional-edition-for-linux-documentation/\">Intel® C++ Compiler Professional Edition for Linux – Documentation - Intel® Software Network</a>&#160;» <a href=\"/Linux\" title=\"Linux\">Linux</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://software.intel.com/en-us/mpi-library/documentation/get-started\">Intel(R) C++ Compiler User and Reference Guides</a> covers Intrinsics</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://software.intel.com/sites/landingpage/IntrinsicsGuide/\">Intel® Intrinsics Guide</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Manuals\">Manuals</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=6\" title=\"Edit section: Manuals\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<h2><span class=\"mw-headline\" id=\"Instructions\">Instructions</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=7\" title=\"Edit section: Instructions\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.intel.com/content/www/us/en/architecture-and-technology/64-ia-32-architectures-software-developer-vol-2a-manual.html\">Intel® 64 and IA-32 Architectures Software Developer’s Manual Volume 2A: Instruction Set Reference, A-M</a> (pdf)</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.intel.com/content/www/us/en/architecture-and-technology/64-ia-32-architectures-software-developer-vol-2b-manual.html\">Intel® 64 and IA-32 Architectures Software Developer’s Manual Volume 2B: Instruction Set Reference, N-Z</a> (pdf)</li></ul>\n<h2><span class=\"mw-headline\" id=\"Optimization_Guides\">Optimization Guides</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=8\" title=\"Edit section: Optimization Guides\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://software.intel.com/en-us/download/intel-64-and-ia-32-architectures-optimization-reference-manual\">Intel 64 and IA32 Architectures Optimization Reference Manual</a> (pdf) Appendix C Instruction Latencies</li></ul>\n<h1><span class=\"mw-headline\" id=\"See_also\">See also</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=9\" title=\"Edit section: See also\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/AMD\" title=\"AMD\">AMD</a></li>\n<li> <a href=\"/Microsoft\" title=\"Microsoft\">Microsoft</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Forum_Posts\">Forum Posts</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Intel&amp;action=edit&amp;section=10\" title=\"Edit section: Forum Posts\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.stmintz.com/ccc/index.php?id=211203\">Reply from Intel about BSF/BSR</a> by <a href=\"/Severi_Salminen\" title=\"Severi Salminen\">Severi Salminen</a>, <a href=\"/CCC\" title=\"CCC\">CCC</a>, January 31, 2002&#160;» <a href=\"/BitScan\" title=\"BitScan\">BitScan</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.talkchess.com/forum/viewtopic.php?t=40996\">Intel vs AMD: which does your engine prefer?</a> by <a href=\"/Albert_Silver\" title=\"Albert Silver\">Albert Silver</a>, <a href=\"/CCC\" title=\"CCC\">CCC</a>, November 04, 2011&#160;» <a href=\"/AMD\" title=\"AMD\">AMD</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.talk