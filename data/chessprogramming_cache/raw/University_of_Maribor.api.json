      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * University of Maribor</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:UniverzaMaribor.jpg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/0/04/UniverzaMaribor.jpg/330px-UniverzaMaribor.jpg\" width=\"300\" height=\"225\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/0/04/UniverzaMaribor.jpg/500px-UniverzaMaribor.jpg 1.5x, https://upload.wikimedia.org/wikipedia/commons/0/04/UniverzaMaribor.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:UniverzaMaribor.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>University of Maribor, main building  <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></div></div></div>\n<p><b>University of Maribor</b>,<br />\nin <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Maribor\">Maribor</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Slovenia\">Slovenia</a> was established in 1975 <sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\">&#91;2&#93;</a></sup>.\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Chess_Programs\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Chess Programs</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#People\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">People</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#External_Links\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#References\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"Chess_Programs\">Chess Programs</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Maribor&amp;action=edit&amp;section=1\" title=\"Edit section: Chess Programs\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/BBChess_(SI)\" title=\"BBChess (SI)\">BBChess</a> <sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\">&#91;3&#93;</a></sup></li>\n<li> <a href=\"/MinkoChess\" title=\"MinkoChess\">MinkoChess</a></li>\n<li> <a href=\"/QuTeChess\" title=\"QuTeChess\">QuTeChess</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"People\">People</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Maribor&amp;action=edit&amp;section=2\" title=\"Edit section: People\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Borko_Bo%C5%A1kovi%C4%87\" title=\"Borko Bošković\">Borko Bošković</a></li>\n<li> <a href=\"/Janez_Brest\" title=\"Janez Brest\">Janez Brest</a></li>\n<li> <a href=\"/Sa%C5%A1o_Greiner\" title=\"Sašo Greiner\">Sašo Greiner</a></li>\n<li> <a href=\"/index.php?title=Nikola_Guid&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Nikola Guid (page does not exist)\">Nikola Guid</a></li>\n<li> <a href=\"/index.php?title=Damjan_Strnad&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Damjan Strnad (page does not exist)\">Damjan Strnad</a></li>\n<li> <a href=\"/Ale%C5%A1_Zamuda\" title=\"Aleš Zamuda\">Aleš Zamuda</a></li>\n<li> <a href=\"/Viljem_%C5%BDumer\" title=\"Viljem Žumer\">Viljem Žumer</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"External_Links\">External Links</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Maribor&amp;action=edit&amp;section=3\" title=\"Edit section: External Links\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/University_of_Maribor\">University of Maribor from Wikipedia</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://commons.wikimedia.org/wiki/Category:University_of_Maribor\">Category:University of Maribor - Wikimedia Commons</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://www.um.si/en/Pages/default.aspx\">Univerza v Mariboru - official website</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://feri.um.si/en/\">\tFaculty of Electrical Engineering and Computer Science</a> (FERI)</li></ul>\n<dl><dd> <a rel=\"nofollow\" class=\"external text\" href=\"https://cs.feri.um.si/en/\">Institute of Computer Science</a></dd>\n<dd> <a rel=\"nofollow\" class=\"external text\" href=\"https://labraj.feri.um.si/en/General_Information\">Computer Architecture and Languages Laboratory</a></dd></dl>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"http://labraj.uni-mb.si/en/index.php/Programming_language_Zero\">Programming language Zero - Computer Architecture and Languages Laboratory</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Maribor&amp;action=edit&amp;section=4\" title=\"Edit section: References\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">↑</a></span> <span class=\"reference-text\"><a rel=\"nofollow\" class=\"external text\" href=\"https://commons.wikimedia.org/wiki/Category:University_of_Maribor\">Category:University of Maribor - Wikimedia Commons</a></span>\n</li>\n