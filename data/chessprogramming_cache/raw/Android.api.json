      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Software\" title=\"Software\">Software</a> * Android</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:Android_robot_(2014-2019).svg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/Android_robot_%282014-2019%29.svg/330px-Android_robot_%282014-2019%29.svg.png\" width=\"300\" height=\"352\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/Android_robot_%282014-2019%29.svg/500px-Android_robot_%282014-2019%29.svg.png 1.5x, https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/Android_robot_%282014-2019%29.svg/960px-Android_robot_%282014-2019%29.svg.png 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:Android_robot_(2014-2019).svg\" class=\"internal\" title=\"Enlarge\"></a></div>Android robot</div></div></div> \n<p><b>Android</b>,<br />\na <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Mobile_device\">mobile device</a> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Operating_system\">operating system</a> based on the <a href=\"/Linux\" title=\"Linux\">Linux</a> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Linux_kernel\">kernel</a>, with <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Middleware\">middleware</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Software_library\">libraries</a> and <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Application_programming_interface\">APIs</a> written in <a href=\"/C\" title=\"C\">C</a>, and <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Application_software\">applications</a> running on a <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Application_framework\">framework</a> including <a href=\"/Java\" title=\"Java\">Java-compatible</a> libraries based on <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Apache_Harmony\">Apache Harmony</a>. Android is developed by the <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Open_Handset_Alliance\">Open Handset Alliance</a> led by <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Google\">Google Inc.</a> <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup> . \n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#See_also\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">See also</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Publications\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Publications</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Postings\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Postings</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#2008_...\"><span class=\"tocnumber\">3.1</span> <span class=\"toctext\">2008 ...</span></a></li>\n<li class=\"toclevel-2 tocsection-5\"><a href=\"#2010_...\"><span class=\"tocnumber\">3.2</span> <span class=\"toctext\">2010 ...</span></a></li>\n<li class=\"toclevel-2 tocsection-6\"><a href=\"#2015_...\"><span class=\"tocnumber\">3.3</span> <span class=\"toctext\">2015 ...</span></a></li>\n<li class=\"toclevel-2 tocsection-7\"><a href=\"#2020_...\"><span class=\"tocnumber\">3.4</span> <span class=\"toctext\">2020 ...</span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-8\"><a href=\"#External_Links\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">External Links</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-9\"><a href=\"#ChessBase\"><span class=\"tocnumber\">4.1</span> <span class=\"toctext\">ChessBase</span></a></li>\n<li class=\"toclevel-2 tocsection-10\"><a href=\"#Computer_Chess\"><span class=\"tocnumber\">4.2</span> <span class=\"toctext\">Computer Chess</span></a></li>\n<li class=\"toclevel-2 tocsection-11\"><a href=\"#Development\"><span class=\"tocnumber\">4.3</span> <span class=\"toctext\">Development</span></a></li>\n<li class=\"toclevel-2 tocsection-12\"><a href=\"#Misc\"><span class=\"tocnumber\">4.4</span> <span class=\"toctext\">Misc</span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-13\"><a href=\"#References\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"See_also\">See also</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Android&amp;action=edit&amp;section=1\" title=\"Edit section: See also\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Chess_for_Android\" title=\"Chess for Android\">Chess for Android</a></li>\n<li> <a href=\"/Category:Android\" title=\"Category:Android\">Engines for Android</a></li>\n<li> <a href=\"/index.php?title=Scid_on_the_Go&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Scid on the Go (page does not exist)\">Scid on the Go</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Publications\">Publications</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Android&amp;action=edit&amp;section=2\" title=\"Edit section: Publications\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/index.php?title=Corey_Abshire&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Corey Abshire (page does not exist)\">Corey Abshire</a>, <a href=\"/Dmitri_Gusev\" title=\"Dmitri Gusev\">Dmitri Gusev</a> (<b>2015</b>). <i><a rel=\"nofollow\" c