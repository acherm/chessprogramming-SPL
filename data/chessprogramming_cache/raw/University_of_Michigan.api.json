      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * University of Michigan</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:Burton_Tower.jpg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Burton_Tower.jpg/330px-Burton_Tower.jpg\" width=\"300\" height=\"225\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Burton_Tower.jpg/500px-Burton_Tower.jpg 1.5x, https://upload.wikimedia.org/wikipedia/commons/thumb/a/ac/Burton_Tower.jpg/960px-Burton_Tower.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:Burton_Tower.jpg\" class=\"internal\" title=\"Enlarge\"></a></div><a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Burton_Memorial_Tower\">Burton Memorial Tower</a> <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></div></div></div> \n<p><b>University of Michigan</b>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Ann_Arbor,_Michigan\">Ann Arbor</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Michigan\">Michigan</a> the <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/United_States\">United States</a>.\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#People\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">People</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Chess_Programs\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Chess Programs</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Publications\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Publications</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#External_Links\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-5\"><a href=\"#References\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"People\">People</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Michigan&amp;action=edit&amp;section=1\" title=\"Edit section: People\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Mike_Alexander\" title=\"Mike Alexander\">Mike Alexander</a></li>\n<li> <a href=\"/David_E._Goldberg\" title=\"David E. Goldberg\">David E. Goldberg</a></li>\n<li> <a href=\"/Mark_Hersey\" title=\"Mark Hersey\">Mark Hersey</a></li>\n<li> <a href=\"/James_Kister\" title=\"James Kister\">James Kister</a></li>\n<li> <a href=\"/Ed_Northam\" title=\"Ed Northam\">Ed Northam</a></li>\n<li> <a href=\"/Jack_O%E2%80%99Keefe\" title=\"Jack O’Keefe\">Jack O’Keefe</a></li>\n<li> <a href=\"/Shaul_Markovitch\" title=\"Shaul Markovitch\">Shaul Markovitch</a></li>\n<li> <a href=\"/index.php?title=Judith_Spencer_Olson&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Judith Spencer Olson (page does not exist)\">Judith Spencer Olson</a></li>\n<li> <a href=\"/Walter_R._Reitman\" title=\"Walter R. Reitman\">Walter R. Reitman</a></li>\n<li> <a href=\"/Fred_Swartz\" title=\"Fred Swartz\">Fred Swartz</a></li>\n<li> <a href=\"/Yizao_Wang\" title=\"Yizao Wang\">Yizao Wang</a></li>\n<li> <a href=\"/index.php?title=Bruce_Wilcox&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Bruce Wilcox (page does not exist)\">Bruce Wilcox</a></li>\n<li> <a href=\"/Joe_Winograd\" title=\"Joe Winograd\">Joe Winograd</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Chess_Programs\">Chess Programs</span><span class=\"mw-edits