      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Periodical\" title=\"Periodical\">Periodical</a> * Computerschach und Spiele</b>\n</p><p><b>Computerschach und Spiele</b> (<b>CSS</b>),\na German computer chess periodical. From 1983 until 2005 it was a paper magazine by <a href=\"/Dieter_Steinwender\" title=\"Dieter Steinwender\">Dieter Steinwender</a> and <a href=\"/Frederic_Friedel\" title=\"Frederic Friedel\">Frederic Friedel</a>. Since 2005 <b>CSS</b> is available online with Steinwender as sole publisher and editor in chief <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup>. The scanned CSS issues from 1983 until 2000 were available as DVD from <i>Steinwender EDV-Beratung</i> <sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\">&#91;2&#93;</a></sup> <sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\">&#91;3&#93;</a></sup> <sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\">&#91;4&#93;</a></sup>. \n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Selected_Authors\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Selected Authors</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Forum_Posts\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Forum Posts</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#External_Links\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#References\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"Selected_Authors\">Selected Authors</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Computerschach_und_Spiele&amp;action=edit&amp;section=1\" title=\"Edit section: Selected Authors\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<p><sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\">&#91;5&#93;</a></sup>\n</p>\n<ul><li> <a href=\"/Ingo_Alth%C3%B6fer\" title=\"Ingo Althöfer\">Ingo Althöfer</a></li>\n<li> <a href=\"/Ingo_Bauer\" title=\"Ingo Bauer\">Ingo Bauer</a></li>\n<li> <a href=\"/Karsten_Bauermeister\" title=\"Karsten Bauermeister\">Karsten Bauermeister</a></li>\n<li> <a href=\"/index.php?title=Hubert_Bednorz&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Hubert Bednorz (page does not exist)\">Hubert Bednorz</a></li>\n<li> <a href=\"/Lars_Bremer\" title=\"Lars Bremer\">Lars Bremer</a></li>\n<li> <a href=\"/Murray_Campbell\" title=\"Murray Campbell\">Murray Campbell</a></li>\n<li> <a href=\"/index.php?title=Helmut_Conrady&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Helmut Conrady (page does not exist)\">Helmut Conrady</a></li>\n<li> <a href=\"/Thorsten_Czub\" title=\"Thorsten Czub\">Thorsten Czub</a></li>\n<li> <a href=\"/Chrilly_Donninger\" title=\"Chrilly Donninger\">Chrilly Donninger</a></li>\n<li> <a href=\"/Martin_Fierz\" title=\"Martin Fierz\">Martin Fierz</a></li>\n<li> <a href=\"/Dirk_Frickenschmidt\" title=\"Dirk Frickenschmidt\">Dirk Frickenschmidt</a></li>\n<li> <a href=\"/G%C3%B6ran_Grottling\" title=\"Göran Grottling\">Göran Grottling</a></li>\n<li> <a href=\"/index.php?title=Michael_Gurevich&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Michael Gurevich (page does not exist)\">Michael Gurevich</a></li>\n<li> <a href=\"/Timo_Haupt\" title=\"Timo Haupt\">Timo Haupt (né Klaustermeyer)</a></li>\n<li> <a href=\"/Marty_Hirsch\" title=\"Marty Hirsch\">Marty Hirsch</a></li>\n<li> <a href=\"/Feng-hsiung_Hsu\" title=\"Feng-hsiung Hsu\">Feng-hsiung Hsu</a></li>\n<li> <a href=\"/index.php?title=Thoralf_Karlsson&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Thoralf Karlsson (page does not exist)\