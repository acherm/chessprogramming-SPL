      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * Moscow State University</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:Moscow_State_University_crop.jpg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a0/Moscow_State_University_crop.jpg/330px-Moscow_State_University_crop.jpg\" width=\"300\" height=\"171\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/a/a0/Moscow_State_University_crop.jpg/500px-Moscow_State_University_crop.jpg 1.5x, https://upload.wikimedia.org/wikipedia/commons/thumb/a/a0/Moscow_State_University_crop.jpg/960px-Moscow_State_University_crop.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:Moscow_State_University_crop.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>MSU main Building in early autumn <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></div></div></div> \n<p><b>Lomonosov Moscow State University</b>, <br />\n<a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Moscow\">Moscow</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Russia\">Russia</a>, previously known as <b>Lomonosov University</b> or MSU (университет Ломоносова, Universitét Lomonósova; МГУ, MGU), is the oldest and largest university in Russia, founded in 1755, the university was renamed in honor of its founder, <a href=\"/Mathematician#MLomonosov\" title=\"Mathematician\">Mikhail Lomonosov</a>, in 1940 <sup id=\"cite_ref-2\" class=\"reference\"><a href=\"#cite_note-2\">&#91;2&#93;</a></sup>. \n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#People\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">People</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-2\"><a href=\"#Art\"><span class=\"tocnumber\">1.1</span> <span class=\"toctext\">Art</span></a></li>\n<li class=\"toclevel-2 tocsection-3\"><a href=\"#Computer_Science\"><span class=\"tocnumber\">1.2</span> <span class=\"toctext\">Computer Science</span></a></li>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#Computer_Chess\"><span class=\"tocnumber\">1.3</span> <span class=\"toctext\">Computer Chess</span></a></li>\n<li class=\"toclevel-2 tocsection-5\"><a href=\"#Mathematics\"><span class=\"tocnumber\">1.4</span> <span class=\"toctext\">Mathematics</span></a></li>\n<li class=\"toclevel-2 tocsection-6\"><a href=\"#Physics\"><span class=\"tocnumber\">1.5</span> <span class=\"toctext\">Physics</span></a></li>\n<li class=\"toclevel-2 tocsection-7\"><a href=\"#Politics\"><span class=\"tocnumber\">1.6</span> <span class=\"toctext\">Politics</span></a></li>\n<li class=\"toclevel-2 tocsection-8\"><a href=\"#Psychology\"><span class=\"tocnumber\">1.7</span> <span class=\"toctext\">Psychology</span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-9\"><a href=\"#Chess_Programs\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Chess Programs</span></a></li>\n<li class=\"toclevel-1 tocsection-10\"><a href=\"#Computers\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Computers</span></a></li>\n<li class=\"toclevel-1 tocsection-11\"><a href=\"#See_also\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">See also</span></a></li>\n<li class=\"toclevel-1 tocsection-12\"><a href=\"#External_Links\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-13\"><a href=\"#References\"><span class=\"tocnumber\">6</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"People\">People</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=1\" title=\"Edit section: People\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<p><sup id=\"cite_ref-3\" class=\"reference\"><a href=\"#cite_note-3\">&#91;3&#93;</a></sup> <sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\">&#91;4&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Art\">Art</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=2\" title=\"Edit section: Art\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a href=\"/Arts#Kandinsky\" title=\"Arts\">Wassily Kandinsky</a></li></ul>\n<h2><span class=\"mw-headline\" id=\"Computer_Science\">Computer Science</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=3\" title=\"Edit section: Computer Science\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a href=\"/Vadim_Anshelevich\" title=\"Vadim Anshelevich\">Vadim Anshelevich</a></li>\n<li> <span id=\"Brusentsov\"></span><a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Nikolay_Brusentsov\">Nikolay Brusentsov</a>&#160;» <i><a href=\"/Moscow_State_University#Sobolev\" title=\"Moscow State University\">Sergei Sobolev</a>, <a href=\"/Moscow_State_University#Setun\" title=\"Moscow State University\">Setun</a></i></li>\n<li> <a href=\"/Mathematician#Ershov\" title=\"Mathematician\">Andrey Ershov</a> <sup id=\"cite_ref-5\" class=\"reference\"><a href=\"#cite_note-5\">&#91;5&#93;</a></sup></li>\n<li> <a href=\"/Mathematician#CARHoare\" title=\"Mathematician\">Charles Antony Richard Hoare</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Ivannikov.htm\">Viktor Petrovich Ivannikov</a> ® </li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Kotelnikov.htm\">Vladimir Alexandrovich Kotelnikov</a> ® </li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Korolev.htm\">Lev Nikolaevich Korolev</a> ® </li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Lavrov.htm\">Svyatoslav Sergeevich Lavrov</a> ®</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Melnikov.htm\">Vladimir Andreevich Melnikov</a> ®</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Myamlin.htm\">Anatoliy Nikolaevich Myamlin</a> ®</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Sokolov.htm\">Andrey Andreevich Sokolov</a> ®</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Tomilin.htm\">Alexander Nikolaevich Tomilin</a> ®</li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/galglory_en/Zhogolev.htm\">Evgeny Andreevich Zhogolev</a> ®</li></ul>\n<h2><span class=\"mw-headline\" id=\"Computer_Chess\">Computer Chess</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=4\" title=\"Edit section: Computer Chess\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a href=\"/Georgy_Adelson-Velsky\" title=\"Georgy Adelson-Velsky\">Georgy Adelson-Velsky</a></li>\n<li> <a href=\"/Ivan_Bonkin\" title=\"Ivan Bonkin\">Ivan Bonkin</a></li>\n<li> <a href=\"/Alexander_Brudno\" title=\"Alexander Brudno\">Alexander Brudno</a></li>\n<li> <a href=\"/Mikhail_Donskoy\" title=\"Mikhail Donskoy\">Mikhail Donskoy</a></li>\n<li> <a href=\"/Edward_Komissarchik\" title=\"Edward Komissarchik\">Edward Komissarchik</a></li>\n<li> <a href=\"/Alexander_Kronrod\" title=\"Alexander Kronrod\">Alexander Kronrod</a></li>\n<li> <a href=\"/Vladimir_Makhnychev\" title=\"Vladimir Makhnychev\">Vladimir Makhnychev</a></li>\n<li> <a href=\"/Michael_G._Malkovsky\" title=\"Michael G. Malkovsky\">Michael G. Malkovsky</a></li>\n<li> <a href=\"/Vladislav_Y._Shchukin\" title=\"Vladislav Y. Shchukin\">Vladislav Y. Shchukin</a></li>\n<li> <a href=\"/Mikhail_R._Shura-Bura\" title=\"Mikhail R. Shura-Bura\">Mikhail R. Shura-Bura</a></li>\n<li> <a href=\"/Michael_Tsfasman\" title=\"Michael Tsfasman\">Michael Tsfasman</a></li>\n<li> <a href=\"/Victor_Zakharov\" title=\"Victor Zakharov\">Victor Zakharov</a></li></ul>\n<h2><span class=\"mw-headline\" id=\"Mathematics\">Mathematics</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=5\" title=\"Edit section: Mathematics\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<dl><dd> <i>see <a href=\"/Mathematician\" title=\"Mathematician\">Mathematician</a></i></dd></dl>\n<ul><li> <a href=\"/Mathematician#Velsky\" title=\"Mathematician\">Georgy Adelson-Velsky</a></li>\n<li> <a href=\"/Mathematician#Brudno\" title=\"Mathematician\">Alexander Brudno</a></li>\n<li> <a href=\"/Mathematician#Bugaev\" title=\"Mathematician\">Nikolai Bugaev</a></li>\n<li> <a href=\"/Mathematician#Dynkin\" title=\"Mathematician\">Eugene Dynkin</a></li>\n<li> <a href=\"/Mathematician#Egorov\" title=\"Mathematician\">Dmitri Egorov</a></li>\n<li> <a href=\"/Mathematician#Gelfand\" title=\"Mathematician\">Israel Gelfand</a></li>\n<li> <a href=\"/Mathematician#Keldysh\" title=\"Mathematician\">Mstislav Keldys</a></li>\n<li> <a href=\"/Mathematician#Kolmogorov\" title=\"Mathematician\">Andrey Kolmogorov</a></li>\n<li> <a href=\"/Mathematician#Kronrod\" title=\"Mathematician\">Alexander Kronrod</a></li>\n<li> <a href=\"/Mathematician#Kummer\" title=\"Mathematician\">Ernst Kummer</a></li>\n<li> <a href=\"/Mathematician#Landis\" title=\"Mathematician\">Evgenii Landis</a></li>\n<li> <a href=\"/Mathematician#Luzin\" title=\"Mathematician\">Nikolai Luzin</a></li>\n<li> <a href=\"/Mathematician#AShen\" title=\"Mathematician\">Alexander Shen</a></li>\n<li> <a href=\"/Mathematician#ShuraBura\" title=\"Mathematician\">Mikhail R. Shura-Bura</a></li>\n<li> <a href=\"/Mathematician#Stechkin\" title=\"Mathematician\">Sergey Stechkin</a></li>\n<li> <a href=\"/Mathematician#VAUspensky\" title=\"Mathematician\">Vladimir Andreevich Uspensky</a> <sup id=\"cite_ref-6\" class=\"reference\"><a href=\"#cite_note-6\">&#91;6&#93;</a></sup></li></ul>\n<h2><span class=\"mw-headline\" id=\"Physics\">Physics</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=6\" title=\"Edit section: Physics\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Nikolay_Konstantinov\">Nikolay Konstantinov</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Lev_Landau\">Lev Landau</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Andrei_Sakharov\">Andrei Sakharov</a></li></ul>\n<h2><span class=\"mw-headline\" id=\"Politics\">Politics</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=7\" title=\"Edit section: Politics\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Mikhail_Gorbachev\">Mikhail Gorbachev</a></li></ul>\n<h2><span class=\"mw-headline\" id=\"Psychology\">Psychology</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=8\" title=\"Edit section: Psychology\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li> <a href=\"/index.php?title=Oleg_K._Tichomirov&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Oleg K. Tichomirov (page does not exist)\">Oleg K. Tichomirov</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Chess_Programs\">Chess Programs</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=9\" title=\"Edit section: Chess Programs\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Shura-Bura%27s_Program\" title=\"Shura-Bura&#39;s Program\">Shura-Bura's Program</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Computers\">Computers</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Moscow_State_University&amp;action=edit&amp;section=10\" title=\"Edit section: Computers\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Lomonosov_Supercomputer\" title=\"Lomonosov Supercomputer\">Lomonosov Supercomputer</a></li>\n<li> <a href=\"/M-20\" title=\"M-20\">M-20</a></li>\n<li> <span id=\"Setun\"></span><a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Setun\">Setun</a>&#160;» <a href=\"/Mathematician#Sobolev\" title=\"Mathematician\">Sergei Sobolev</a>, <a href=\"/Mathematician#Brusentsov\" title=\"Mathematician\">Nikolay Brusentsov</a></li>\n<li> <a rel=\"nofollow\" class=\"external text\" href=\"http://www.computer-museum.ru/english/setun.htm\">Development of ternary computers at Moscow State University</a> ® </li></ul>\n<h1><span class=\"mw-headline