      "*": "<div class=\"mw-parser-output\"><p><b><a href=\"/Main_Page\" title=\"Main Page\">Home</a> * <a href=\"/Organizations\" title=\"Organizations\">Organizations</a> * University of Warsaw</b>\n</p>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:302px;\"><a href=\"/File:Pasteura_5.jpg\" class=\"image\"><img alt=\"\" src=\"https://upload.wikimedia.org/wikipedia/commons/thumb/8/85/Pasteura_5.jpg/330px-Pasteura_5.jpg\" width=\"300\" height=\"218\" class=\"thumbimage\" srcset=\"https://upload.wikimedia.org/wikipedia/commons/thumb/8/85/Pasteura_5.jpg/500px-Pasteura_5.jpg 1.5x, https://upload.wikimedia.org/wikipedia/commons/thumb/8/85/Pasteura_5.jpg/960px-Pasteura_5.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/File:Pasteura_5.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>University of Warsaw, Faculty of Physics <sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></div></div></div>\n<p><b>University of Warsaw</b>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Warsaw\">Warsaw</a>, <a rel=\"nofollow\" class=\"external text\" href=\"https://en.wikipedia.org/wiki/Poland\">Poland</a>.\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#People\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">People</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Chess_Programs\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Chess Programs</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#External_Links\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">External Links</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#References\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h1><span class=\"mw-headline\" id=\"People\">People</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Warsaw&amp;action=edit&amp;section=1\" title=\"Edit section: People\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Adam_Kujawski\" title=\"Adam Kujawski\">Adam Kujawski</a></li>\n<li> <a href=\"/index.php?title=%C5%81ukasz_Lew&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Łukasz Lew (page does not exist)\">Łukasz Lew</a></li>\n<li> <a href=\"/index.php?title=Bart%C5%82omiej_Macieja&amp;action=edit&amp;redlink=1\" class=\"new\" title=\"Bartłomiej Macieja (page does not exist)\">Bartłomiej Macieja</a></li>\n<li> <a href=\"/Tomasz_Michniewski\" title=\"Tomasz Michniewski\">Tomasz Michniewski</a></li>\n<li> <a href=\"/Arkadiusz_Paterek\" title=\"Arkadiusz Paterek\">Arkadiusz Paterek</a></li>\n<li> <a href=\"/Jakub_Pawlewicz\" title=\"Jakub Pawlewicz\">Jakub Pawlewicz</a></li>\n<li> <a href=\"/Michal_Rudolf\" title=\"Michal Rudolf\">Michal Rudolf</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"Chess_Programs\">Chess Programs</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Warsaw&amp;action=edit&amp;section=2\" title=\"Edit section: Chess Programs\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1>\n<ul><li> <a href=\"/Gosu\" title=\"Gosu\">Gosu</a> by <a href=\"/Arkadiusz_Paterek\" title=\"Arkadiusz Paterek\">Arkadiusz Paterek</a></li>\n<li> <a href=\"/Joanna\" title=\"Joanna\">Joanna</a> by <a href=\"/Adam_Kujawski\" title=\"Adam Kujawski\">Adam Kujawski</a></li></ul>\n<h1><span class=\"mw-headline\" id=\"External_Links\">External Links</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=University_of_Warsaw&amp;action=edit&amp;section=3\" title=\"Edit section: External Links\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h1